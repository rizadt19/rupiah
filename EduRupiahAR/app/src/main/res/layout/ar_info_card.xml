<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardElevation="8dp"
    app:cardBackgroundColor="#FFFFFF"
    android:layout_margin="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/textViewNominal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nominal: Rp XXXXXX"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#333333" />

        <TextView
            android:id="@+id/textViewYear"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Year: YYYY"
            android:textSize="16sp"
            android:textColor="#555555"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Security Features:"
            android:textSize="18sp"
            android:textStyle="italic"
            android:textColor="#444444"/>

        <TextView
            android:id="@+id/textViewSecurityFeatures"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Details about security features..."
            android:textSize="14sp"
            android:textColor="#666666"
            android:lineSpacingMultiplier="1.1"
            android:maxLines="3"
            android:ellipsize="end"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Description:"
            android:textSize="18sp"
            android:textStyle="italic"
            android:textColor="#444444"/>

        <TextView
            android:id="@+id/textViewDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Detailed description of the currency..."
            android:textSize="14sp"
            android:textColor="#666666"
            android:lineSpacingMultiplier="1.1"
            android:maxLines="4"
            android:ellipsize="end"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>
